{
    auto_https off
    grace_period 5s
}

:{$CADDY_CONTAINER_PORT} {
    # Backend API
    reverse_proxy /docs http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /items/* http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /learners/* http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /interactions/* http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /analytics/* http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /pipeline/* http://backend:{$BACKEND_CONTAINER_PORT}
    reverse_proxy /health http://backend:{$BACKEND_CONTAINER_PORT}

    # React dashboard
    handle / {
        root * /srv/react
        try_files {path} /index.html
        file_server
    }

    # Task 2B — WebSocket channel for webchat
    handle /ws/chat {
        reverse_proxy http://nanobot:{$NANOBOT_WEBCHAT_CONTAINER_PORT}
    }

    # Task 2B — Flutter web client
    handle_path /flutter* {
        root * /srv/flutter
        try_files {path} /index.html
        file_server
    }

    # pgAdmin
    handle /utils/pgadmin/* {
        uri strip_prefix /utils/pgadmin
        reverse_proxy http://pgadmin:{$CONST_PGADMIN_CONTAINER_PORT}
    }

    # VictoriaLogs UI
    handle /utils/victorialogs/* {
        uri strip_prefix /utils/victorialogs
        reverse_proxy http://victorialogs:{$CONST_VICTORIALOGS_CONTAINER_PORT}
    }

    # VictoriaTraces UI
    handle /utils/victoriatraces/* {
        uri strip_prefix /utils/victoriatraces
        reverse_proxy http://victoriatraces:{$CONST_VICTORIATRACES_CONTAINER_PORT}
    }

    # Qwen Code API
    handle /v1/* {
        reverse_proxy http://qwen-code-api:{$QWEN_CODE_API_CONTAINER_PORT}
    }
}
